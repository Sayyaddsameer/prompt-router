# =============================================================================
# .env.example — All environment variables for the Prompt Router service.
# Copy this to .env and fill in your values. Never commit .env.
# =============================================================================

# ─── OpenAI API ────────────────────────────────────────────────────────────
# Your OpenAI API key (required)
OPENAI_API_KEY=sk-...your-key-here...

# Model used for intent classification (fast + cheap)
CLASSIFIER_MODEL=gpt-4o-mini

# Model used for expert response generation (higher quality)
RESPONDER_MODEL=gpt-4o-mini

# OpenAI API base URL (override for Azure / local proxies)
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Routing ───────────────────────────────────────────────────────────────
# Confidence score below which intent is treated as 'unclear' (0.0–1.0)
CONFIDENCE_THRESHOLD=0.7

# Path to the JSON file containing expert system prompts
PROMPTS_FILE=prompts.json

# ─── Logging ───────────────────────────────────────────────────────────────
# Path to the JSON Lines log file
LOG_FILE=route_log.jsonl

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── API Server ────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
